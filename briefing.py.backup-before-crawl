                            && !e.href.includes("Kreuzwortraetsel")
                            && !e.href.includes("backstage")
                            && !e.href.includes("premium")
                        )'''
                    )
                    logger.info(f"{section_url}: {len(article_links)} Artikel-Links")

                    # Auf /weltplus/ nur Links mit /plus crawlen (Rest sind Werbebanner)
                    if assume_plus:
                        article_links = [l for l in article_links if "/plus" in l["href"]]
                        logger.info(f"  Davon echte Plus-Links: {len(article_links)}")

                    seen_urls = set()
                    for link in article_links[:15]:
                        url = link["href"].split("?")[0]
                        if url in plus_articles or url in seen_urls:
                            continue
                        seen_urls.add(url)
                        logger.info(f"  Crawle: {link['text'][:50]}...")
                        try:
                            page.goto(link["href"], timeout=30000, wait_until="domcontentloaded")
                            time.sleep(1)

                            # Plus-Erkennung: /plus in URL = definitiv Plus
                            # Auf /meinung/ ohne /plus prüfen wir das HTML
                            html = page.content()
                            url_is_plus = "/plus" in url
                            if not url_is_plus and not assume_plus:
                                is_plus = (
                                    '"isPaid":true' in html
                                    or '"isPremiumContent":true' in html
                                    or '"isPaywalled":true' in html
                                )
                                if not is_plus:
                                    continue

                            # Autor extrahieren
                            autor = None
                            for selector in [
                                '[class*="author"]',
                                'meta[name="author"]',
                            ]:
                                el = page.query_selector(selector)
                                if el:
                                    autor = el.get_attribute("content") if selector.startswith("meta") else el.inner_text().strip()
                                    # "Von " entfernen, Zeilenumbrüche normalisieren
                                    if autor:
                                        autor = autor.replace("\n", " ").strip()
                                        if autor.startswith("Von "):
                                            autor = autor[4:]
                                        break

                            # Artikeltext extrahieren (main hat den vollen Text, article nur Banner)
                            article_body = page.query_selector('main')
                            if not article_body:
                                article_body = page.query_selector('.c-article-text, [class*="article-body"], article')
                            if article_body:
                                text = article_body.inner_text()
                                if len(text) > 300:
                                    plus_articles[url] = {
                                        "titel": link["text"],
                                        "text": text[:2000],
                                        "url": url,
                                        "autor": autor,
                                    }
                                    logger.info(f"Welt+ Artikel: {link['text'][:60]}... (Autor: {autor})")

                        except Exception as e:
                            logger.warning(f"Artikel-Fehler: {e}")

                except Exception as e:
                    logger.warning(f"Sektion {section_url} Fehler: {e}")

            browser.close()

    except Exception as e:
        logger.error(f"Playwright Fehler: {e}")

    logger.info(f"Welt+ Artikel gecrawlt: {len(plus_articles)}")
    return plus_articles


def gather_welt_uebersicht(datum_str):
    """Teil 2: Welt Überblick — Echte Daten + Claude-Einordnung"""
    logger.info("=== Teil 2: Welt Überblick ===")

    raw_articles = scrape_welt_articles()
    plus_data = scrape_welt_plus_articles()

    if not raw_articles and not plus_data:
        logger.warning("Keine Artikel von welt.de — Fallback auf Web Search")
        return _welt_fallback(datum_str)

    # Nach Ressort gruppieren (Startseiten-Artikel)
    grouped = defaultdict(list)
    for a in raw_articles:
        ressort = a["ressort"]
        if ressort == "Finanzen":
            ressort = "Wirtschaft"
        grouped[ressort].append(a)

    # Artikelliste für Zusammenfassung (inkl. Plus-Artikel)
    articles_text = ""
    if plus_data:
        articles_text += "\nWELTplus (Paywall-Artikel):\n"
        for url, pa in list(plus_data.items())[:10]:
            line = f"  - {pa['titel']}"
            if pa.get("text"):
                line += f" (Auszug: {pa['text'][:200]}...)"
            articles_text += line + "\n"
    for ressort, arts in sorted(grouped.items()):
        articles_text += f"\n{ressort}:\n"
        for a in arts[:6]:
            articles_text += f"  - {a['titel']}\n"

    summary = ""
    try:
        summary = call_claude(
            "Du bist ein Redaktionsanalyst. Antworte mit 2-3 Sätzen, kein JSON, kein Markdown.",
            f"Was sind die Schwerpunkte auf welt.de heute ({datum_str})?\n{articles_text}\n\nFasse in 2-3 Sätzen zusammen.",
            max_search=0,
        ) or ""
    except Exception as e:
        logger.warning(f"Zusammenfassung fehlgeschlagen: {e}")

    # Datenstruktur aufbauen — WELTplus ZUERST (eigene Sektion!)
    ressorts_data = {}

    # Plus-Artikel als eigene Sektion — mit KI-Zusammenfassung + Einschätzung
    if plus_data:
        plus_list = list(plus_data.values())[:10]

        # Batch-Call: Claude fasst alle Plus-Artikel zusammen + gibt Einschätzung
        plus_summaries = _summarize_plus_articles(plus_list)

        plus_entries = []
        for i, pa in enumerate(plus_list):
            summary_data = plus_summaries.get(str(i), {}) if plus_summaries else {}
            plus_entries.append({
                "titel": pa["titel"],
                "autor": pa.get("autor"),
                "kommentare": 0,
                "beschreibung": summary_data.get("zusammenfassung", ""),
                "einschaetzung": summary_data.get("einschaetzung", ""),
                "url": pa["url"],
                "zeit": "",
                "plus": True,
            })
        ressorts_data["WELTplus"] = plus_entries
        logger.info(f"WELTplus Sektion: {len(ressorts_data['WELTplus'])} Artikel mit KI-Einschätzung")

    # Startseiten-Artikel nach Ressort
    for ressort, arts in sorted(grouped.items()):
        arts_sorted = sorted(arts, key=lambda x: x.get("datum", ""), reverse=True)
        ressorts_data[ressort] = []
        for a in arts_sorted[:5]:
            zeit = ""
            if a.get("datum"):
                try:
                    dt = datetime.fromisoformat(a["datum"].replace("Z", "+00:00"))
                    dt_local = dt + timedelta(hours=1)
                    zeit = dt_local.strftime("%H:%M Uhr")
                except Exception:
                    pass

            entry = {
                "titel": a["titel"],
                "autor": a.get("autor"),
                "kommentare": a.get("kommentare", 0),
                "beschreibung": None,
                "url": a["url"],
                "zeit": zeit,
                "plus": a.get("plus", False),
            }
            ressorts_data[ressort].append(entry)

    data = {
        "zusammenfassung": summary.strip(),
        "ressorts": ressorts_data,
        "meistgelesen": [],
    }

    total = sum(len(v) for v in data["ressorts"].values())
    plus_count = len(ressorts_data.get("WELTplus", []))
    logger.info(f"Welt Überblick: {total} Artikel in {len(data['ressorts'])} Ressorts ({plus_count} WELTplus)")
    return data


def _summarize_plus_articles(plus_list):
    """Batch-Call: Claude fasst Plus-Artikel zusammen + gibt redaktionelle Einschätzung."""
    logger.info(f"KI-Einschätzung für {len(plus_list)} WELTplus-Artikel...")

    articles_prompt = ""
    for i, pa in enumerate(plus_list):
        autor = pa.get("autor", "unbekannt")
        text = pa.get("text", "")[:800]
        articles_prompt += f"\n---\nARTIKEL {i}:\nTitel: {pa['titel']}\nAutor: {autor}\nText: {text}\n"

    response = call_claude(
        """Du bist ein erfahrener Redakteur. Analysiere WELTplus-Artikel für den Chefredakteur.
Antworte AUSSCHLIESSLICH mit validem JSON, ohne Erklärungen davor oder danach.""",
        f"""Analysiere diese WELTplus-Artikel:
{articles_prompt}

Antworte mit diesem JSON-Format:
```json
{{
    "0": {{
        "zusammenfassung": "Worum geht es? (2-3 kurze, prägnante Sätze)",
        "einschaetzung": "Redaktionelle Einschätzung: Wie ist der Artikel aufgebaut? Was macht ihn lesenswert? Welchen Angle wählt der Autor? (2-3 Sätze)"
    }},
    "1": {{ ... }}
}}
```

REGELN:
- "zusammenfassung": Knapp und klar — worum es im Kern geht. Keine Floskeln.
- "einschaetzung": Wie ein Kollege in der Redaktionskonferenz. Was macht das Stück interessant? Exklusive Quellen? Starke These? Überraschender Angle? Relevanz für die Redaktion?
- Nummerierung muss den Artikel-Nummern entsprechen (0, 1, 2, ...)""",
        max_search=0,
    )

    data = parse_json_response(response)
    if data:
        logger.info(f"KI-Einschätzung erhalten für {len(data)} Artikel")
    else:
        logger.warning("KI-Einschätzung fehlgeschlagen")
    return data or {}


def _welt_fallback(datum_str):
    """Fallback: Web Search wenn Crawling fehlschlägt."""
    response = call_claude(
        "Du bist ein Redaktionsanalyst. Antworte AUSSCHLIESSLICH mit validem JSON.",
        f'Suche nach aktuellen Artikeln auf welt.de vom {datum_str}.\n\nANTWORTE NUR MIT JSON:\n```json\n{{"zusammenfassung": "...", "ressorts": {{"Politik": [{{"titel": "...", "url": "..."}}]}}, "meistgelesen": []}}\n```',
        max_search=10,
